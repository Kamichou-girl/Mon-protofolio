{
  "name": "portfolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4200",
    "build": "ng build --configuration production && node scripts/fix-index-paths.js && node scripts/vercel-output.js",
    "build:local": "ng build --configuration development",
    "watch": "ng build --watch",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "deploy:vercel": "ng build --configuration production && vercel --prod",
    "deploy:netlify": "ng build --configuration production && netlify deploy --prod --dir=dist/portfolio",
    "deploy:github": "ng build --base-href / && npm run deploy:github",
    "serve:prod": "ng serve --configuration production --port 4201",
    "analyze": "ng build --stats-json && npx webpack-bundle-analyzer dist/portfolio/stats.json"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-browser-dynamic": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
